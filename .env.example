# --------------------------------------------------
# Django core
# --------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --------------------------------------------------
# Database
# --------------------------------------------------
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_CONN_MAX_AGE=60

# --------------------------------------------------
# SyncServer integration
# --------------------------------------------------
# IMPORTANT:
# Base URL MUST include /api/v1
# Current runtime headers are:
# - X-Device-Token -> SYNC_DEVICE_TOKEN
# - X-User-Token -> SYNC_ROOT_USER_TOKEN or per-user binding token
SYNC_SERVER_URL=http://syncserver:8000/api/v1
SYNC_ROOT_USER_TOKEN=
SYNC_DEVICE_TOKEN=
SYNC_SERVER_TIMEOUT=10
