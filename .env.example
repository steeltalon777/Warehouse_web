# --------------------------------------------------
# Django core
# --------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --------------------------------------------------
# Global organization identity
# --------------------------------------------------
ORGANIZATION_FULL_NAME=Общество с ограниченной ответственностью Автоматизированные системы "Горизонт"
ORGANIZATION_SHORT_NAME=ООО АС "Горизонт"

# --------------------------------------------------
# Database
# --------------------------------------------------
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_CONN_MAX_AGE=60

# --------------------------------------------------
# SyncServer integration
# --------------------------------------------------
# IMPORTANT:
# Base URL MUST include /api/v1
# Current runtime headers are:
# - X-Device-Token -> SYNC_DEVICE_TOKEN
# - X-User-Token -> SYNC_ROOT_USER_TOKEN or per-user binding token
SYNC_SERVER_URL=http://syncserver:8000/api/v1
SYNC_ROOT_USER_TOKEN=9d5c0496-a32b-4d55-be0d-1fcfede4fd5a
SYNC_DEVICE_TOKEN=9eed7417-a854-4d9a-90ed-3d3c98714e07
SYNC_SERVER_TIMEOUT=10
