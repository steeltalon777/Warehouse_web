# Django core
DJANGO_ENV=production
DJANGO_ENV_FILE=.env
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=change-this-secret-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,147.45.102.135

# Django service database (auth/session/admin only)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=warehouse_web
DB_USER=warehouse_web
DB_PASSWORD=change-me
DB_HOST=pg-main
DB_PORT=5432
DB_CONN_MAX_AGE=60

# SyncServer integration (required)
SYNC_SERVER_URL=http://syncserver:8000
SYNC_SITE_ID=<uuid-from-sync-bootstrap>
SYNC_DEVICE_ID=<uuid-from-sync-bootstrap>
SYNC_DEVICE_TOKEN=<registration-token-from-sync-bootstrap>
SYNC_CLIENT_VERSION=warehouse-web/1.0
SYNC_SERVER_TIMEOUT=10

# Production security
SECURE_SSL_REDIRECT=False
CSRF_TRUSTED_ORIGINS=http://147.45.102.135,http://localhost