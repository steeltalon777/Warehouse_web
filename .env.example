# --------------------------------------------------
# Django core
# --------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# --------------------------------------------------
# Database
# --------------------------------------------------
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_CONN_MAX_AGE=60

# --------------------------------------------------
# SyncServer integration (canonical)
# --------------------------------------------------
# IMPORTANT:
# Base URL MUST include /api/v1
SYNC_SERVER_URL=http://syncserver:8000/api/v1
SYNC_SERVER_SERVICE_TOKEN=change-me
SYNC_SERVER_TIMEOUT=10

# Optional default acting context for technical/service flows only
SYNC_DEFAULT_ACTING_USER_ID=
SYNC_DEFAULT_ACTING_SITE_ID=

# --------------------------------------------------
# Legacy / deprecated device-auth values
# --------------------------------------------------
# Django SSR web client must NOT use these for business/admin requests.
# Left here only while old code is being removed.
SYNC_SITE_ID=
SYNC_DEVICE_ID=
SYNC_DEVICE_TOKEN=
SYNC_CLIENT_VERSION=warehouse-web/1.0